{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "rootDir": ".",
    "paths": {
      "@data/*": ["./topics/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
